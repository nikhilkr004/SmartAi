<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recording Setup"
            android:textColor="#102027"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Configure your session parameters below."
            android:textColor="#546E7A"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="SESSION NAME"
            android:textColor="#006064"
            android:textSize="10sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_dialog_input"
            android:padding="4dp">

            <EditText
                android:id="@+id/etSessionName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@null"
                android:drawableEnd="@drawable/ic_edit"
                android:drawablePadding="8dp"
                android:hint="Session name"
                android:paddingEnd="16dp"
                android:paddingStart="16dp"
                android:textSize="14sp" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="TYPE"
            android:textColor="#006064"
            android:textSize="10sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="2"
            android:rowCount="2">

            <!-- Coding -->
            <LinearLayout
                android:id="@+id/btnTypeCoding"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_type_unselected"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/ivCoding"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_type_coding" />

                <TextView
                    android:id="@+id/tvCoding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Coding"
                    android:textColor="#546E7A"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Math -->
            <LinearLayout
                android:id="@+id/btnTypeMath"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_type_unselected"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/ivMath"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_type_math" />

                <TextView
                    android:id="@+id/tvMath"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Math"
                    android:textColor="#546E7A"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Aptitude -->
            <LinearLayout
                android:id="@+id/btnTypeAptitude"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_type_unselected"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/ivAptitude"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_type_aptitude" />

                <TextView
                    android:id="@+id/tvAptitude"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Aptitude"
                    android:textColor="#546E7A"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- General -->
            <LinearLayout
                android:id="@+id/btnTypeGeneral"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/bg_type_selected"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/ivGeneral"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_type_general"
                    app:tint="#006064" />

                <TextView
                    android:id="@+id/tvGeneral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="General"
                    android:textColor="#006064"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANCEL"
                android:textColor="#546E7A" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:paddingEnd="32dp"
                android:paddingStart="32dp"
                android:text="START"
                android:textColor="@color/white"
                app:backgroundTint="#006064"
                app:cornerRadius="16dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
